#!/bin/bash

source "$CONFIG_DIR/theme.sh"
PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####

sketchybar --bar position=top height=$BAR_HEIGHT blur_radius=0 color=$BAR_COLOR y_offset=-2 notch_offset=4

##### Defaults #####

default=(
    padding_left=5
    padding_right=5
    icon.font="$NERD_FONT:Bold:$ICON_SIZE"
    label.font="$FONT:Bold:$LABEL_SIZE"
    icon.color=$WHITE
    label.color=$WHITE
    background.drawing=off
    background.color=$ITEM_BG_COLOR
    background.border_color=$WHITE
    background.height=24
    background.corner_radius=5
    icon.padding_left=$ITEM_PADDING
    icon.padding_right=$ITEM_PADDING
    label.padding_left=$ITEM_PADDING
    label.padding_right=$ITEM_PADDING
)
sketchybar --default "${default[@]}"

# Center ŌĆö next calendar event today (see plugins/calendar.sh)
sketchybar --add item next_event_meta center \
    --set next_event_meta \
    background.drawing=off \
    icon="¾░āŁ" \
    icon.padding_left=10 \
    icon.padding_right=2 \
    label.font="$FONT:Bold:$LABEL_SIZE_SM" \
    label.padding_left=2 \
    label.padding_right=4 \
    label.drawing=off

sketchybar --add item next_event center \
    --set next_event \
    update_freq=600 \
    script="$PLUGIN_DIR/calendar.sh" \
    icon.drawing=off \
    label.font="$FONT:Bold:13.0" \
    label.max_chars=48 \
    label.align=center \
    label.padding_left=2 \
    background.drawing=off \
    --subscribe next_event system_woke

sketchybar --add bracket next_event_b next_event_meta next_event \
    --set next_event_b \
    background.color=$BRACKET_BG_COLOR \
    background.drawing=on \
    background.height=$BRACKET_HEIGHT \
    background.corner_radius=$BRACKET_RADIUS

# Right Side Items
# Calendar
sketchybar --add item date right \
    --set date \
    update_freq=3600 \
    script="$PLUGIN_DIR/date.sh" \
    icon.drawing=off \
    label.font="$FONT:Regular:$LABEL_SIZE_XS" \
    label.padding_left=6 \
    width=0 \
    label.align=center \
    background.drawing=off \
    y_offset=6 \
    --subscribe date system_woke

sketchybar --add item time right \
    --set time \
    update_freq=30 \
    script="$PLUGIN_DIR/time.sh" \
    icon.drawing=off \
    label.font="$FONT:Bold:13.0" \
    label.padding_left=6 \
    width=0 \
    label.align=center \
    background.drawing=off \
    y_offset=-4 \
    --subscribe time system_woke

# Spacer
sketchybar --add item spacer_right right \
    --set spacer_right \
    width=91 \
    background.drawing=off \
    label.drawing=off \
    icon.drawing=off

# Battery
sketchybar --add item battery right \
    --set battery \
    script="$PLUGIN_DIR/battery.sh" \
    background.drawing=off \
    icon.padding_right=0 \
    label.width=40 \
    label.padding_right=12 \
    update_freq=60

# CPU usage
sketchybar --add item cpu_usage right \
    --set cpu_usage \
    script="$PLUGIN_DIR/cpu_usage.sh" \
    background.drawing=off \
    update_freq=5 \
    icon.padding_right=0 \
    label.width=36 \
    icon="’ŗø" \
    icon.font="$NERD_FONT:Bold:$ICON_SIZE_LG"

# RAM usage
sketchybar --add item ram_usage right \
    --set ram_usage \
    script="$PLUGIN_DIR/ram_usage.sh" \
    background.drawing=off \
    update_freq=5 \
    label.width=36 \
    icon="¾░Źø" \
    icon.padding_right=0 \
    icon.font="$NERD_FONT:Bold:$ICON_SIZE_LG"

# SSD usage
sketchybar --add item ssd_usage right \
    --set ssd_usage \
    script="$PLUGIN_DIR/ssd_usage.sh" \
    background.drawing=off \
    update_freq=60 \
    label.width=36 \
    icon="’āć" \
    icon.padding_right=0 \
    icon.font="$NERD_FONT:Bold:$ICON_SIZE_LG"

# Keyboard language
sketchybar --add item keyboard right \
    --set keyboard \
    script="$PLUGIN_DIR/keyboard.sh" \
    background.drawing=off \
    icon="¾░īī" \
    icon.padding_right=0 \
    icon.font="$NERD_FONT:Bold:$ICON_SIZE_LG" \
    --subscribe keyboard input_change

# Bracket for calendar
sketchybar --add bracket right_side date time \
    --set right_side background.color=$BRACKET_BG_COLOR \
    background.drawing=on \
    background.height=$BRACKET_HEIGHT \
    background.corner_radius=$BRACKET_RADIUS

# Bracket for sys_info
sketchybar --add bracket sys_info cpu_usage ram_usage ssd_usage battery keyboard \
    --set sys_info background.color=$BRACKET_BG_COLOR \
    background.drawing=on \
    background.height=$BRACKET_HEIGHT \
    background.corner_radius=$BRACKET_RADIUS

# Left Side Items
sketchybar --add item apple left \
    --set apple \
    icon="’īé" \
    icon.font="$NERD_FONT:Bold:$ICON_SIZE_XL" \
    background.drawing=off \
    icon.padding_right=0 \
    icon.padding_left=4 \
    padding_right=0 \
    icon.y_offset=1 \
    icon.color=$ACCENT_COLOR

sketchybar --add event aerospace_workspace_change
sketchybar --add event aerospace_monitor_change
sketchybar --add event aerospace_focus_changed

TEMP_WORKSPACES="T1 T2 T3"

for sid in $(aerospace list-workspaces --all) $TEMP_WORKSPACES; do
    sketchybar --add item space.$sid left \
        --subscribe space.$sid aerospace_workspace_change \
        --set space.$sid \
        drawing=off \
        label.drawing=on \
        label.font="$APP_FONT:Regular:16.0" \
        background.drawing=on \
        background.color=$BAR_COLOR \
        icon="$sid" \
        icon.padding_left=10 \
        label.padding_right=15 \
        label.padding_left=0 \
        label.y_offset=-1 \
        click_script="aerospace workspace $sid" \
        script="$PLUGIN_DIR/aerospace.sh $sid"
done

for mid in $(aerospace list-monitors | cut -c1); do
    focused=$(aerospace list-workspaces --monitor "$mid" --visible)
    for sid in $(aerospace list-workspaces --monitor "$mid"); do
        apps=$(aerospace list-windows --workspace "$sid" | awk -F'|' '{gsub(/^ *| *$/, "", $2); print $2}')

        icon_strip=" "
        if [ -n "$apps" ]; then
            while read -r app; do
                icon_strip+=" $($PLUGIN_DIR/icon_map_fn.sh "$app")"
            done <<<"${apps}"
        else
            icon_strip=""
        fi

        has_windows=$( [ -n "$apps" ] && echo "on" || echo "off" )
        is_focused=$( [ "$sid" = "$focused" ] && echo "on" || echo "$has_windows" )

        sketchybar --set space.$sid display=$mid drawing=$is_focused label="$icon_strip"
    done
done

sketchybar --add item icon_refresher left \
    --set icon_refresher drawing=off \
    width=0 \
    script="$PLUGIN_DIR/icon_refresh.sh" \
    --subscribe icon_refresher aerospace_focus_changed aerospace_workspace_change

sketchybar --add item front_app left \
    --set front_app icon.drawing=off \
    label.font="$NERD_FONT:Bold:$LABEL_SIZE" \
    script="$PLUGIN_DIR/front_app.sh" \
    background.drawing=on \
    background.color=$BRACKET_BG_COLOR \
    background.height=$BRACKET_HEIGHT \
    background.corner_radius=$BRACKET_RADIUS \
    --subscribe front_app front_app_switched

for mid in $(aerospace list-monitors | cut -c1); do
    space_items=""
    for sid in $(aerospace list-workspaces --monitor "$mid") $TEMP_WORKSPACES; do
        space_items+="space.$sid "
    done
    sketchybar --add bracket left_bracket_$mid apple $space_items \
        --set left_bracket_$mid \
        display=$mid \
        background.color=$BRACKET_BG_COLOR \
        background.drawing=on \
        background.height=$BRACKET_HEIGHT \
        background.corner_radius=$BRACKET_RADIUS
done

sketchybar --update
